      "name": "Users",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// const firstname = pm.variables.replaceIn('{{$randomFirstName}}');",
                  "// const lastname = pm.variables.replaceIn('{{$randomLastName}}');",
                  "",
                  "// pm.environment.set(\"firstname\", firstname);",
                  "// pm.environment.set(\"lastname\", lastname);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"bookingid\", response.bookingid);",
                  "",
                  "pm.environment.set(\"firstname\", response.booking.firstname);",
                  "pm.environment.set(\"lastname\", response.booking.lastname);",
                  "",
                  "",
                  "pm.test (\"verify status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "})",
                  "",
                  "pm.test (\"Verify Booking ID is a number\", function () {",
                  "const response = pm.response.json();",
                  "pm.expect(response.bookingid).to.be.a('number');",
                  "})",
                  "",
                  "pm.test (\"Verify Booking has firsname\", function (){",
                  "const response = pm.response.json();",
                  "pm.expect(response.booking.firstname).to.be.a(\"string\")",
                  "",
                  "})",
                  "",
                  "pm.test(\"Booking has lastname\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.booking.lastname).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"Booking has totalprice\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.booking.totalprice).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"Booking has depositpaid\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.booking.depositpaid).to.be.a(\"boolean\");",
                  "});",
                  "",
                  "pm.test(\"Booking has checkin date\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.booking.bookingdates.checkin).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"Booking has checkout date\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.booking.bookingdates.checkout).to.be.a(\"string\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
