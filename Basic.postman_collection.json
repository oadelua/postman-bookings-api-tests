        {
          "name": "Update Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Firstname has not changed\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.firstname).to.eql(pm.environment.get(\"firstname\"));",
                  "});",
                  "",
                  "pm.test(\"Lastname has not changed\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.lastname).to.eql(pm.environment.get(\"lastname\"));",
                  "});",
                  "",
                  "",
                  "pm.test(\"Additional needs updated to Breakfast and Dinner\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.additionalneeds).to.eql(\"Breakfast and Dinner\");",
                  "});",
                  "",
                  "",
                  "pm.test(\"Total price has not changed\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.totalprice).to.eql(300);",
                  "});",
                  "",
                  "pm.test(\"Deposit paid has not changed\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.depositpaid).to.eql(true);",
                  "});",
                  "",
                  "pm.test(\"Checkin date has not changed\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.bookingdates.checkin).to.eql(\"2025-01-01\");",
                  "});",
                  "",
                  "pm.test(\"Checkout date has not changed\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.bookingdates.checkout).to.eql(\"2025-01-07\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
